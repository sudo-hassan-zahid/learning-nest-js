DATABASE_URL="postgresql://postgres:postgres@localhost:5460/nestdb?schema=public"
REDIS_URL="redis://localhost:6399"

JWT_ACCESS_SECRET="change-me-access"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3000
APP_URL="http://localhost:3000"

# Cloudinary — free at cloudinary.com (25 GB storage, 25 GB bandwidth/month)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# SMTP — works with Gmail (App Password), Resend, Brevo, Mailgun, etc.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Blog <no-reply@yourdomain.com>"
